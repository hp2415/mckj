#
# 桌面端强制更新（后端下发“最新版本信息”）
# 把本文件复制为 backend/.env 后生效（重启后端进程）
#

# 例如 "1.0.1"
DESKTOP_LATEST_VERSION=1.0.1

# 支持相对路径（推荐）或完整 URL
# 相对路径示例：把安装包放到 backend/downloads/ 后，写 /downloads/xxx.exe
DESKTOP_INSTALLER_URL=/downloads/WeChatAI_Assistant_Setup.exe

# true / false（默认 true）
DESKTOP_FORCE_UPDATE=true

# 可选：更新说明
DESKTOP_RELEASE_NOTES=自动更新测试：1.0.1

# 可选：静态目录自定义（不配则默认 backend/media 与 backend/downloads）
# MEDIA_DIR=D:/data/wechat_ai/media
# DOWNLOADS_DIR=D:/data/wechat_ai/downloads

# ----------------------------------------------------------------------
# 任务分配 LLM（与画像分析 profile_llm_* 独立；管理后台 system_configs 优先）
# 未配置时回退 profile_llm_* / 全局 llm_* 默认值
# ----------------------------------------------------------------------
# TASK_ALLOCATION_LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# TASK_ALLOCATION_LLM_API_KEY=
# TASK_ALLOCATION_LLM_MODEL=qwen-max

# 任务分配 worker 并发（定时 06:00 入队后并行执行；管理后台可在线调整）
# TASK_ALLOCATION_WORKER_ENABLED=1
# TASK_ALLOCATION_WORKER_CONCURRENCY=4

# ----------------------------------------------------------------------
# 米城主系统 MiBuddy 联动（客资认领/收藏等）
# 开发: http://localhost:8000/mibuddy  测试: https://t.idatamind.com/mibuddy
# ----------------------------------------------------------------------
# MIBUDDY_BASE_URL=https://t.idatamind.com/mibuddy
# MIBUDDY_API_KEY=

# ----------------------------------------------------------------------
# 微信语音转写（MiBuddy submit_file_trans_request / get_file_trans_result）
# 测试阶段建议 VOICE_TRANSCRIBE_WORKER_ENABLED=0，在管理后台「语音转写控制台」手动操作
# ----------------------------------------------------------------------
# VOICE_TRANSCRIBE_WORKER_ENABLED=0
# VOICE_MIN_DURATION_SEC=5
# VOICE_TRANSCRIBE_SUBMIT_BATCH=10
# VOICE_TRANSCRIBE_POLL_BATCH=20

# 同步入库时自动转写（每 15 分钟语音增量同步后触发）
# 仅对「已绑定销售微信号 + 接通 + 有录音 + 时长≥VOICE_MIN_DURATION_SEC」的新通话转写；
# 转写不触发画像，转写客户由「夜间增量画像」统一画像。
# 测试阶段默认关闭（0）；历史积累数据请在管理后台「语音转写控制台」手动转写。
# VOICE_AUTO_TRANSCRIBE_ON_SYNC=0

# 电话外呼通话：MiBuddy history_call_record（转写由接口直接返回）
# 在管理后台「语音 → 电话通话同步」按时间区间手动同步；明细见「电话通话明细」。
